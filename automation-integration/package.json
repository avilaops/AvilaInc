{
  "name": "automation-integration",
  "version": "1.0.0",
  "description": "GitHub Integration for Avila Automation Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch backend --exec ts-node backend/github-routes.ts",
    "build": "tsc",
    "build:frontend": "cd frontend && tsc",
    "build:backend": "cd backend && tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "keywords": ["github", "automation", "integration"],
  "author": "Avila Inc",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  }
}